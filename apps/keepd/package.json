{
  "name": "@keepai/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.cjs",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:copy": "mkdir -p public && rm -rf public/* && cp -r ../ui/dist/frontend/* ./public/",
    "dev": "tsx src/start.ts",
    "start": "node dist/start.cjs",
    "test": "vitest run",
    "clean": "rimraf dist public",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^8.0.0",
    "@keepai/connectors": "file:../../packages/connectors",
    "@keepai/db": "file:../../packages/db",
    "@keepai/nostr-rpc": "file:../../packages/nostr-rpc",
    "@keepai/proto": "file:../../packages/proto",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.2.0"
  }
}
